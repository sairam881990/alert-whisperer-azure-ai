# ============================================================
# Alert Whisperer — Environment Configuration
# Copy this file to .env and fill in actual values
# ============================================================

# --- General ---
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=INFO

# --- Azure AD ---
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# --- Kusto / ADX (MCP Server) ---
KUSTO_CLUSTER_URL=https://yourcluster.eastus.kusto.windows.net
KUSTO_DATABASE=YourDatabase
KUSTO_MCP_SERVER_URL=http://localhost:3001
KUSTO_QUERY_TIMEOUT_SECONDS=120

# --- Confluence (MCP Server) ---
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_MCP_SERVER_URL=http://localhost:3002
CONFLUENCE_SPACE_KEYS=["RUNBOOKS","OPS","DE"]

# --- ICM / Incident Management (MCP Server) ---
ICM_MCP_SERVER_URL=http://localhost:3003
ICM_API_BASE_URL=https://icm.yourcompany.com/api
ICM_API_KEY=your-icm-api-key
ICM_POLL_INTERVAL_SECONDS=30

# --- Log Analytics (MCP Server) ---
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id
LOG_ANALYTICS_MCP_SERVER_URL=http://localhost:3004
LOG_ANALYTICS_DEFAULT_TIMESPAN=P1D

# --- LLM / Azure OpenAI ---
LLM_PROVIDER=azure_openai
LLM_API_KEY=your-openai-api-key
LLM_API_BASE=https://your-openai.openai.azure.com/
LLM_API_VERSION=2024-02-01
LLM_DEPLOYMENT_NAME=gpt-4o
LLM_EMBEDDING_DEPLOYMENT=text-embedding-3-large
LLM_EMBEDDING_DIMENSIONS=3072
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# --- Microsoft Teams ---
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-azure-search-admin-key
AZURE_SEARCH_INDEX_NAME=alert-whisperer-kb

# --- RAG ---
RAG_VECTOR_STORE_PATH=data/vector_store
RAG_COLLECTION_NAME=alert_whisperer_kb
RAG_CHILD_CHUNK_TOKENS=450
RAG_PARENT_CHUNK_TOKENS=1200
RAG_CHUNK_OVERLAP_TOKENS=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3
RAG_HYBRID_ALPHA=0.6
RAG_RERANK_ENABLED=true
RAG_USE_DEDICATED_RERANKER=false
RAG_DEDICATED_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
RAG_QUERY_REWRITING_ENABLED=true
RAG_RAG_FUSION_ENABLED=true
RAG_SELF_RAG_ENABLED=true
RAG_SEMANTIC_RERANKING_ENABLED=true
RAG_SEMANTIC_CHUNKING_ENABLED=true
RAG_SEMANTIC_CHUNKING_PERCENTILE=25.0

# --- Routing ---
ROUTING_OWNERSHIP_FILE=config/pipeline_ownership.json
ROUTING_ESCALATION_TIMEOUT_MINUTES=30
